<UserControl
    x:Class="DevToolsUno.Diagnostics.Views.ResourcesPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:controls="using:Avalonia.Controls"
    xmlns:views="using:DevToolsUno.Diagnostics.Views"
    automation:AutomationProperties.Name="Resources inspection page">
    <Grid x:Name="LayoutRoot"
          MinHeight="0"
          MinWidth="0"
          ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ProviderColumn"
                              Width="1.2*"
                              MinWidth="280" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition x:Name="ContentColumn"
                              Width="1.8*"
                              MinWidth="520" />
        </Grid.ColumnDefinitions>

        <Grid MinHeight="0"
              MinWidth="0"
              Margin="0,0,12,0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="Providers" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding InspectionTargetSummary}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Command="{Binding RefreshCommand}"
                            Content="Refresh"
                            automation:AutomationProperties.Name="Refresh resources" />
                    <Button Command="{Binding ExpandAllCommand}"
                            Content="Expand"
                            automation:AutomationProperties.Name="Expand all providers" />
                    <Button Command="{Binding CollapseAllCommand}"
                            Content="Collapse"
                            automation:AutomationProperties.Name="Collapse all providers" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <controls:TreeDataGrid x:Name="ProviderTree"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Source="{Binding ProviderTreeSource}"
                                       automation:AutomationProperties.Name="Resource providers" />
            </Border>
        </Grid>

        <Border x:Name="PaneSplitter"
                Grid.Column="1"
                Width="8"
                Background="Transparent"
                automation:AutomationProperties.Name="Resize providers and resources panes" />

        <Grid Grid.Column="2"
              Margin="12,0,0,0"
              MinHeight="0"
              MinWidth="0"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                               Text="{Binding SelectedProviderName}" />
                    <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                               Text="{Binding SelectedProviderSummary}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource DevToolsMetaTextStyle}"
                               Text="{Binding SelectedProviderPath}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Command="{Binding CopySelectedKeyCommand}"
                            Content="Copy Key"
                            automation:AutomationProperties.Name="Copy selected resource key" />
                    <Button Command="{Binding CopySelectedValueCommand}"
                            Content="Copy Value"
                            automation:AutomationProperties.Name="Copy selected resource value" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox PlaceholderText="Filter resources by key, type, or provider"
                         Text="{Binding Filter.FilterString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         automation:AutomationProperties.Name="Filter resources" />
                <ToggleButton Grid.Column="1"
                              IsChecked="{Binding IncludeNested, Mode=TwoWay}"
                              Content="Include Nested"
                              automation:AutomationProperties.Name="Toggle nested resource lookup" />
                <ComboBox Grid.Column="2"
                          Width="120"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                          automation:AutomationProperties.Name="Sort resources by" />
                <ToggleButton Grid.Column="3"
                              IsChecked="{Binding SortDescending, Mode=TwoWay}"
                              Content="Descending"
                              automation:AutomationProperties.Name="Toggle descending resource sort" />
            </Grid>

            <Grid Grid.Row="2"
                  MinHeight="0"
                  MinWidth="0"
                  RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Foreground="{ThemeResource DevToolsForegroundCaptionBrush}"
                           Text="{Binding ResourceCountText}" />

                <Border Grid.Row="1"
                        MinHeight="0"
                        MinWidth="0"
                        Style="{StaticResource DevToolsDataPanelBorderStyle}">
                    <controls:TreeDataGrid x:Name="ResourcesGrid"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Source="{Binding ResourceSource}"
                                           automation:AutomationProperties.Name="Resources grid" />
                </Border>
            </Grid>

            <Border Grid.Row="3"
                    MinHeight="0"
                    MinWidth="0"
                    Style="{StaticResource DevToolsDataPanelBorderStyle}">
                <views:ResourceValueDetailsView x:Name="DetailsView"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                DataContext="{Binding Details}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
