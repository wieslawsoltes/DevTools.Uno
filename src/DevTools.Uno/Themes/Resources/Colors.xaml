<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="DevToolsBackdropColor">#66FFFFFF</Color>
            <Color x:Key="DevToolsShellSurfaceColor">#FFF7F8FA</Color>
            <Color x:Key="DevToolsPanelSurfaceColor">#FFFFFFFF</Color>
            <Color x:Key="DevToolsSectionSurfaceColor">#FFF3F4F6</Color>
            <Color x:Key="DevToolsFooterSurfaceColor">#FFF0F2F5</Color>
            <Color x:Key="DevToolsSurfaceColor">#FFF8F8FB</Color>
            <Color x:Key="DevToolsSurfaceSubtleColor">#FFF3F4F6</Color>
            <Color x:Key="DevToolsSurfaceMutedColor">#FFE5E7EB</Color>
            <Color x:Key="DevToolsBorderColor">#FFD1D5DB</Color>
            <Color x:Key="DevToolsForegroundColor">#FF111827</Color>
            <Color x:Key="DevToolsForegroundMutedColor">#FF374151</Color>
            <Color x:Key="DevToolsForegroundSubtleColor">#FF6B7280</Color>
            <Color x:Key="DevToolsForegroundCaptionColor">#FF9CA3AF</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="DevToolsBackdropColor">#A0000000</Color>
            <Color x:Key="DevToolsShellSurfaceColor">#FF111318</Color>
            <Color x:Key="DevToolsPanelSurfaceColor">#FF161920</Color>
            <Color x:Key="DevToolsSectionSurfaceColor">#FF1A1D24</Color>
            <Color x:Key="DevToolsFooterSurfaceColor">#FF101216</Color>
            <Color x:Key="DevToolsSurfaceColor">#FF141418</Color>
            <Color x:Key="DevToolsSurfaceSubtleColor">#FF18181B</Color>
            <Color x:Key="DevToolsSurfaceMutedColor">#FF111113</Color>
            <Color x:Key="DevToolsBorderColor">#FF2F2F38</Color>
            <Color x:Key="DevToolsForegroundColor">#FFFFFFFF</Color>
            <Color x:Key="DevToolsForegroundMutedColor">#FFD4D4D8</Color>
            <Color x:Key="DevToolsForegroundSubtleColor">#FFA1A1AA</Color>
            <Color x:Key="DevToolsForegroundCaptionColor">#FF71717A</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
