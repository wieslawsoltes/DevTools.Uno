<UserControl
    x:Class="DevTools.Uno.Diagnostics.Views.HotKeyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    automation:AutomationProperties.Name="Hotkeys page">
    <Grid Padding="{ThemeResource DevToolsPagePadding}"
          RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource DevToolsPageTitleTextStyle}"
                       Text="HotKeys" />
            <TextBlock Style="{StaticResource DevToolsBodyTextStyle}"
                       Text="{Binding SummaryText}" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Style="{StaticResource DevToolsCaptionTextStyle}"
                   Text="{Binding EntryCountText}" />

        <Border Grid.Row="2"
                Style="{StaticResource DevToolsDataPanelBorderStyle}">
            <ListView ItemsSource="{Binding Entries}"
                      Style="{StaticResource DevToolsFlatListViewStyle}"
                      automation:AutomationProperties.Name="Hotkey inventory">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{ThemeResource DevToolsForegroundBrush}" Text="{Binding Element}" />
                            <TextBlock Grid.Column="1" Foreground="{ThemeResource DevToolsForegroundMutedBrush}" Text="{Binding Gesture}" />
                            <TextBlock Grid.Column="2" Foreground="{ThemeResource DevToolsForegroundSubtleBrush}" Text="{Binding Scope}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</UserControl>
